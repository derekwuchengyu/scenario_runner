            <Act name="act_maneuvuergroup_ParameterManeuver">
                <ManeuverGroup name="maneuvuergroup_ParameterManeuver" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Ego"/>
                    </Actors>
                    <Maneuver name="ParameterManeuver">
                        <Event name="DetectEgoHasMovedEvent" priority="parallel" maximumExecutionCount="1">
                            <Action name="Set EgoHasMoved Flag">
                                <GlobalAction>
                                    <ParameterAction parameterRef="FLAG-AV_CONNECTED">
                                        <SetAction value="true"/>
                                    </ParameterAction>
                                </GlobalAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="EgoHasMoved" delay="0.0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Ego"/>
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <SpeedCondition value="0.0" rule="greaterThan"/>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="ValidManeuverEvent" priority="parallel" maximumExecutionCount="1">
                            <Action name="Set Valid Flag">
                                <GlobalAction>
                                    <ParameterAction parameterRef="FLAG-IS_VALID">
                                        <SetAction value="true"/>
                                    </ParameterAction>
                                </GlobalAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="EgoHasMoved" delay="0.0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Ego"/>
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <SpeedCondition value="0.0" rule="greaterThan"/>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="DetectAVConnectionTimeoutEvent" priority="parallel" maximumExecutionCount="1">
                            <Action name="Set AV Connection Timeout Flag">
                                <GlobalAction>
                                    <ParameterAction parameterRef="FLAG-AV_CONNECTION_TIMEOUT">
                                        <SetAction value="true"/>
                                    </ParameterAction>
                                </GlobalAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="EgoTimeout" delay="0.0" conditionEdge="none">
                                        <ByValueCondition>
                                            <SimulationTimeCondition value="30.0" rule="greaterThan"/>
                                        </ByValueCondition>
                                    </Condition>
                                    <Condition name="EgoHasNotMoved" delay="0.0" conditionEdge="none">
                                        <ByValueCondition>
                                            <ParameterCondition parameterRef="FLAG-AV_CONNECTED" value="false" rule="equalTo"/>
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="DetectEgoReachedEndEvent" priority="parallel" maximumExecutionCount="1">
                            <Action name="Set Ego Reached End Flag">
                                <GlobalAction>
                                    <ParameterAction parameterRef="FLAG-EGO_REACHED_END">
                                        <SetAction value="true"/>
                                    </ParameterAction>
                                </GlobalAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="EgoApproachEndWp" delay="0.0" conditionEdge="rising">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Ego"/>
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <ReachPositionCondition tolerance="2.0">
                                                    <Position>
                                                        <LanePosition roadId="22" laneId="1" s="6.0" offset="-0.022100728765565236"/>
                                                    </Position>
                                                </ReachPositionCondition>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="DetectEgoTLEEvent" priority="parallel" maximumExecutionCount="1">
                            <Action name="Set Ego TLE Flag">
                                <GlobalAction>
                                    <ParameterAction parameterRef="FLAG-EGO_TLE">
                                        <SetAction value="true"/>
                                    </ParameterAction>
                                </GlobalAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="EgoHasMoved" delay="45.0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Ego"/>
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <SpeedCondition value="0.0" rule="greaterThan"/>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="DetectEgoCollisionEvent" priority="parallel" maximumExecutionCount="1">
                            <Action name="Set Ego Collision Flag">
                                <GlobalAction>
                                    <ParameterAction parameterRef="FLAG-EGO_COLLISION">
                                        <SetAction value="true"/>
                                    </ParameterAction>
                                </GlobalAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="EgoCollision" delay="0.0" conditionEdge="rising">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Ego"/>
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <CollisionCondition>
                                                    <ByType type="vehicle"/>
                                                </CollisionCondition>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <StartTrigger>
                    <ConditionGroup>
                        <Condition name="act_start" delay="0.0" conditionEdge="rising">
                            <ByValueCondition>
                                <SimulationTimeCondition value="0.0" rule="greaterThan"/>
                            </ByValueCondition>
                        </Condition>
                    </ConditionGroup>
                </StartTrigger>
                <StopTrigger/>
            </Act>
        </Story>
        <StopTrigger>
            <ConditionGroup>
                <Condition name="FLAG-AV_CONNECTION_TIMEOUT_Trigger" delay="0.0" conditionEdge="rising">
                    <ByValueCondition>
                        <ParameterCondition parameterRef="FLAG-AV_CONNECTION_TIMEOUT" value="true" rule="equalTo"/>
                    </ByValueCondition>
                </Condition>
            </ConditionGroup>
            <ConditionGroup>
                <Condition name="FLAG-EGO_REACHED_END_Trigger" delay="0.0" conditionEdge="rising">
                    <ByValueCondition>
                        <ParameterCondition parameterRef="FLAG-EGO_REACHED_END" value="true" rule="equalTo"/>
                    </ByValueCondition>
                </Condition>
            </ConditionGroup>
            <ConditionGroup>
                <Condition name="FLAG-EGO_TLE_Trigger" delay="0.0" conditionEdge="rising">
                    <ByValueCondition>
                        <ParameterCondition parameterRef="FLAG-EGO_TLE" value="true" rule="equalTo"/>
                    </ByValueCondition>
                </Condition>
            </ConditionGroup>
            <ConditionGroup>
                <Condition name="FLAG-EGO_COLLISION_Trigger" delay="0.0" conditionEdge="rising">
                    <ByValueCondition>
                        <ParameterCondition parameterRef="FLAG-EGO_COLLISION" value="true" rule="equalTo"/>
                    </ByValueCondition>
                </Condition>
            </ConditionGroup>
        </StopTrigger>
    </Storyboard>
</OpenSCENARIO>
